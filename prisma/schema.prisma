// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  password     String
  traderType   String?
  tradingStyle String?
  isMentor     Boolean    @default(false)
  isPro        Boolean    @default(false)
  proUnlockedUntil DateTime?
  proGrantedByChallenge Boolean @default(false)
  accountabilityMode Boolean @default(false)
  showOnLeaderboard Boolean @default(false)
  displayName   String?
  createdAt    DateTime   @default(now())
  shownLessons String[]   @default([])
  portfolio    Portfolio?
  trades       Trade[]
  missions     Mission[]
  weeklySummaries WeeklySummary[]
  accountabilityPairsAsUser1 AccountabilityPair[] @relation("PairUser1")
  accountabilityPairsAsUser2 AccountabilityPair[] @relation("PairUser2")
  accountabilityReviewsGiven AccountabilityReview[] @relation("Reviewer")
  accountabilityReviewsReceived AccountabilityReview[] @relation("Reviewee")
  watchlist    Watchlist[]
  alerts       Alert[]
  competitionEntries CompetitionEntry[]
  cohortEntries CohortEntry[]
  monthlyChampionships MonthlyChampion[]
  mentorProfile MentorProfile?
  mentorshipsAsMentor Mentorship[] @relation("MentorRelation")
  mentorshipsAsMentee Mentorship[] @relation("MenteeRelation")
}

model WeeklySummary {
  id                     String   @id @default(cuid())
  userId                 String
  weekStart              DateTime
  weekEnd                DateTime
  tradeCount             Int      @default(0)
  winRate                Float    @default(0)
  ruleBreaks             Int      @default(0)
  emotionDistribution    Json
  avgRiskPerTrade        Float    @default(0)
  checklistCompletionRate Float   @default(0)
  disciplineScore        Int      @default(0)
  createdAt              DateTime @default(now())
  user                   User     @relation(fields: [userId], references: [id])

  @@unique([userId, weekStart])
  @@index([weekStart])
}

model AccountabilityPair {
  id              String   @id @default(cuid())
  user1Id         String
  user2Id         String
  requesterId     String
  status          String   @default("pending")
  weekStart       DateTime
  weekEnd         DateTime
  user1ReviewDone Boolean  @default(false)
  user2ReviewDone Boolean  @default(false)
  createdAt       DateTime @default(now())
  user1           User     @relation("PairUser1", fields: [user1Id], references: [id])
  user2           User     @relation("PairUser2", fields: [user2Id], references: [id])
  reviews         AccountabilityReview[]

  @@index([weekStart])
  @@unique([weekStart, user1Id, user2Id])
}

model AccountabilityReview {
  id         String            @id @default(cuid())
  pairId     String
  reviewerId String
  revieweeId String
  doneWell   String
  mistakes   String
  suggestions String
  createdAt  DateTime          @default(now())
  pair       AccountabilityPair @relation(fields: [pairId], references: [id])
  reviewer   User              @relation("Reviewer", fields: [reviewerId], references: [id])
  reviewee   User              @relation("Reviewee", fields: [revieweeId], references: [id])

  @@unique([pairId, reviewerId])
}

model Portfolio {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique
  balance   Float    @default(100000)
  createdAt DateTime @default(now())
}

model Trade {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  stock     String
  type      String
  orderType String   @default("market")
  targetPrice Float?
  status    String   @default("executed")
  price     Float
  quantity  Int
  charges   Float
  pnl       Float?
  note      String?
  mood      String?
  emotionalState String?
  followedPlan String?
  tradeReason String?
  createdAt DateTime @default(now())
}

model Mission {
  id            String    @id @default(cuid())
  userId        String
  missionNumber Int
  title         String
  completed     Boolean   @default(false)
  completedAt   DateTime?
  user          User      @relation(fields: [userId], references: [id])

  @@unique([userId, missionNumber])
}

model Watchlist {
  id      String   @id @default(cuid())
  user    User     @relation(fields: [userId], references: [id])
  userId  String
  symbol  String
  addedAt DateTime @default(now())

  @@unique([userId, symbol])
}

model Alert {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  symbol      String
  targetPrice Float
  condition   String
  triggered   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Competition {
  id               String             @id @default(cuid())
  title            String
  description      String
  startDate        DateTime
  endDate          DateTime
  prizeDescription String
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  entries          CompetitionEntry[]
}

model CompetitionEntry {
  id            String      @id @default(cuid())
  competitionId String
  userId        String
  joinedAt      DateTime    @default(now())
  competition   Competition @relation(fields: [competitionId], references: [id])
  user          User        @relation(fields: [userId], references: [id])

  @@unique([competitionId, userId])
}

model CohortChallenge {
  id              String       @id @default(cuid())
  title           String
  description     String
  startDate       DateTime
  endDate         DateTime
  isActive        Boolean      @default(true)
  maxParticipants Int          @default(100)
  isPro           Boolean      @default(false)
  entries         CohortEntry[]
  createdAt       DateTime     @default(now())
}

model CohortEntry {
  id                  String          @id @default(cuid())
  challengeId         String
  userId              String
  joinedAt            DateTime        @default(now())
  disciplineScore     Float           @default(0)
  totalTrades         Int             @default(0)
  ruleBreaks          Int             @default(0)
  checklistCompletion Float           @default(0)
  rank                Int?
  challenge           CohortChallenge @relation(fields:[challengeId], references:[id])
  user                User            @relation(fields:[userId], references:[id])

  @@unique([challengeId, userId])
}

model MonthlyChampion {
  id                String   @id @default(cuid())
  userId            String
  month             String
  year              String
  disciplineScore   Float
  proUnlockedUntil  DateTime
  createdAt         DateTime @default(now())
  user              User     @relation(fields:[userId], references:[id])

  @@unique([month, year])
}

model OTP {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model MentorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  isMentor        Boolean  @default(false)
  experienceLevel String
  tradingStyle    String
  bio             String
  maxMentees      Int      @default(3)
  isAvailable     Boolean  @default(true)
  user            User     @relation(fields:[userId], references:[id])
}

model Mentorship {
  id        String   @id @default(cuid())
  mentorId  String
  menteeId  String
  status    String   @default("pending")
  startedAt DateTime?
  createdAt DateTime @default(now())
  mentor    User     @relation("MentorRelation", fields:[mentorId], references:[id])
  mentee    User     @relation("MenteeRelation", fields:[menteeId], references:[id])
  feedback  MentorFeedback[]
}

model MentorFeedback {
  id             String     @id @default(cuid())
  mentorshipId   String
  weekNumber     Int
  whatWentWell   String
  areasToImprove String
  focusNextWeek  String
  createdAt      DateTime   @default(now())
  mentorship     Mentorship @relation(fields:[mentorshipId], references:[id])
}
